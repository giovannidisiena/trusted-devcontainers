{
  "name": "trusted-solidity-foundry-node",
  "image": "trusted/solidity-foundry-node:0.1.0",
  "remoteUser": "auditor",
  "runArgs": [
    "--init",
    "--security-opt=no-new-privileges:true",
    "--cap-drop=ALL",
    "--pids-limit=4096"
  ],
  "containerEnv": {
    "SHELL": "/bin/bash",
    "FOUNDRY_DISABLE_NIGHTLY_WARNING": "true",
    "NPM_CONFIG_IGNORE_SCRIPTS": "true",
    "COREPACK_ENABLE_DOWNLOAD_PROMPT": "0"
  }
}

