# Tool versions used by bin/build-images.
#
# These are intentionally centralized so image rebuilds are reviewable.
# Update them in a normal commit and bump Cargo.toml's package version when the
# new set is ready to use for client work.

FOUNDRY_VERSION=1.0.0
SOLC_SELECT_VERSION=1.0.4
NODE_VERSION=22.11.0
PNPM_VERSION=9.15.4
